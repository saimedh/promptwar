# PromptWars — Environment Variables
# Copy this file to .env and fill in your values.
# For local dev, only GEMINI_API_KEY is required.
# For production (Cloud Run), use GCP_PROJECT + remove GEMINI_API_KEY.

# ── Local dev (API key mode — no GCP creds needed) ──────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Production (Vertex AI mode — leave GEMINI_API_KEY blank) ─
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1

# ── Redis (Memorystore in prod, localhost for local dev) ──────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_TTL_SEC=3600

# ── Gemini model ──────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash-001

# ── Firestore collection name ─────────────────────────────────
FS_COLLECTION=scores

# ── Pub/Sub topic (optional — leave blank to disable) ─────────
# Format: projects/{project}/topics/{topic}
PUBSUB_TOPIC=
